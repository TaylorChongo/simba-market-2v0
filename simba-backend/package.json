{
  "name": "simba-backend",
  "version": "1.0.1",
  "description": "Backend for Simba Market 2.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node -e \"console.log('Using DB URL:', process.env.DATABASE_URL?.replace(/:[^:@]+@/, ':***@'))\" && prisma generate && prisma migrate deploy",
    "dev": "nodemon server.js",
    "prisma:generate": "prisma generate",
    "seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "6.19.3",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "fuse.js": "^7.4.2",
    "groq-sdk": "^1.1.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "6.19.3"
  }
}
