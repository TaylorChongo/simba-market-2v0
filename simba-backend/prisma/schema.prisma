generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CLIENT
  VENDOR
  BRANCH_MANAGER
  BRANCH_STAFF
  ADMIN
}

enum OrderStatus {
  PENDING
  APPROVED
  ASSIGNED
  PREPARING
  READY_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  password         String?        // Made optional for Google Sign-In users
  googleId         String?        @unique
  role             Role           @default(CLIENT)
  branch           String?        // For BRANCH_MANAGER and BRANCH_STAFF
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime       @default(now())
  
  // Relations
  orders           Order[]        @relation("ClientOrders")
  assignedOrders   Order[]        @relation("AssignedTo")
  managedOrders    Order[]        @relation("AssignedBy")
  products         Product[]      @relation("VendorProducts")
  securityLogs     SecurityLog[]
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model SecurityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  // Relations
  user      User?    @relation(fields: [userId], references: [id])
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  code        String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([role, permissionId])
}

model Product {
  id          String      @id @default(uuid())
  name        String
  price       Float
  category    String
  image       String
  description String?
  vendorId    String
  createdAt   DateTime    @default(now())
  
  // Relations
  vendor      User        @relation("VendorProducts", fields: [vendorId], references: [id])
  orderItems  OrderItem[]
  stocks      BranchStock[]
}

model BranchStock {
  id         String   @id @default(uuid())
  productId  String
  branchName String
  stock      Int      @default(0)

  // Relations
  product    Product  @relation(fields: [productId], references: [id])

  @@unique([productId, branchName])
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  totalPrice     Float
  status         OrderStatus @default(PENDING)
  momoReference  String?     // External reference from MTN MoMo
  branchName     String?     // e.g. Simba Supermarket Remera (fulfillment branch)
  deliveryAddress      String?     // e.g. Gisozi, Gasabo, Kigali
  deliveryInstructions String?     // e.g. Opposite Gisozi Sector Office or Near the pharmacy
  depositPaid          Boolean     @default(false)
  depositAmount        Float       @default(0)
  
  assignedTo           String?     // User ID of BRANCH_STAFF
  assignedBy           String?     // User ID of BRANCH_MANAGER
  
  createdAt            DateTime    @default(now())
  
  // Relations
  user           User        @relation("ClientOrders", fields: [userId], references: [id])
  staff          User?       @relation("AssignedTo", fields: [assignedTo], references: [id])
  manager        User?       @relation("AssignedBy", fields: [assignedBy], references: [id])
  items          OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  
  // Relations
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
